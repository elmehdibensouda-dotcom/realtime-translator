# ─────────────────────────────────────────────────────────────────────────────
# RealtimeTranslator – Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# App
DEBUG=true
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
ALLOWED_ORIGINS=["*"]
ALLOWED_HOSTS=["*"]

# ASR provider: deepgram | google | whisper
ASR_PROVIDER=assemblyai
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# GOOGLE_SPEECH_CREDENTIALS_JSON=/path/to/gcp_service_account.json

# Translation provider: deepl | google | llm
TRANSLATION_PROVIDER=deepl
DEEPL_API_KEY=your_deepl_api_key_here
# GOOGLE_TRANSLATE_API_KEY=your_google_key_here

# WebSocket tuning
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10
AUDIO_CHUNK_MS=100

# Capacity
MAX_CONCURRENT_SESSIONS=500
SESSION_TIMEOUT_S=3600

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ASSEMBLYAI_API_KEY=b47f2d35fcaf42029743204346b1584e
