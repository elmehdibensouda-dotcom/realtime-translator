# ─────────────────────────────────────────────────────────────────────────────
# RealtimeTranslator – Backend (FREE VERSION)
# Mode: Web Speech API (Browser) + Google Translate (deep-translator)
# ─────────────────────────────────────────────────────────────────────────────

# App
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
ALLOWED_ORIGINS=["*"]
ALLOWED_HOSTS=["*"]

# Services
FREE_TRANSLATION_MAX_WORKERS=10

# WebSocket
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10

# Capacity
MAX_CONCURRENT_SESSIONS=500
SESSION_TIMEOUT_S=3600

# Security (JWT)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
